# GEO Studio — 前端环境变量
# 复制为 .env 并修改配置（.env 不提交到 Git）

# PocketBase 后端地址
VITE_PB_URL=http://127.0.0.1:8085

# PocketBase 管理员账号（仅本地开发使用）
VITE_PB_EMAIL=admin@geo.local
VITE_PB_PASSWORD=admin123456

# 默认 AI API Key（可选）：填入后系统首次加载会自动启用 API 直连模式
# 智谱 GLM 免费申请：https://open.bigmodel.cn/usercenter/apikeys
VITE_DEFAULT_AI_KEY=
