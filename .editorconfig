# EditorConfig — 跨编辑器统一代码风格
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,ts,jsx,tsx,html,css,json,jsonc}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # Markdown 末尾两空格表示换行

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 2

[*.{bat,cmd}]
end_of_line = crlf
